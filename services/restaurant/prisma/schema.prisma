generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id          String   @id @default(uuid())
  ownerId     String
  name        String
  description String?
  address     String
  latitude    Float
  longitude   Float
  isOpen      Boolean  @default(true)
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])              // getMyRestaurant — avoids full table scan
  @@index([latitude, longitude])  // nearby restaurants query
  @@index([isOpen])               // filter active restaurants
  @@index([name])                 // restaurant name search
}
